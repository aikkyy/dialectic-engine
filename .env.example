# Copy this file to .env.local and adjust as needed.
# .env.local is git-ignored (matched by *.local in .gitignore).

# ─── Antithesis generation ────────────────────────────────────────────────────
# The local Ollama model generates antitheses (free, fully offline). If it's
# ever unavailable, the app AUTOMATICALLY and seamlessly falls back to Claude —
# but only if you set ANTHROPIC_API_KEY below. Leave that blank to stay 100%
# offline (no fallback, no cost).

# ─── Ollama (primary — local, offline, free) ─────────────────────────────────
# Install Ollama (https://ollama.com), then pull the model once:
#   ollama pull qwen2.5:14b
# After the one-time download it needs no internet.
OLLAMA_URL=http://localhost:11434
# Pick by the machine's RAM:
#   qwen2.5:32b → Apple Silicon, 24-32 GB (best quality; keep if replies stay snappy)
#   qwen2.5:14b → Apple Silicon, 16 GB     (the safe, snappy default)
#   qwen2.5:7b  → Intel / low RAM          (keeps the CPU fast)
OLLAMA_MODEL=qwen2.5:14b
# Keep the model resident in RAM between requests so there's no cold-start lag.
#   -1  = never unload (recommended for a kiosk/exhibition)
#   0   = unload immediately   |   "10m" = unload after 10 idle minutes
OLLAMA_KEEP_ALIVE=-1

# ─── Claude (automatic fallback — needs internet + credit) ────────────────────
# Set a funded key to enable the seamless fallback for when Ollama is down.
# Leave blank to stay fully offline. Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ─── Archive "save" QR code ───────────────────────────────────────────────────
# The save-archive QR links a visitor's phone to the styled /archive/print page,
# with the whole archive packed into the URL itself (that page is static — no
# backend — so the data never leaves the phone). The link MUST point at a public
# copy of the app: a phone can't reach the iMac's localhost.
#
# By DEFAULT it points at the exhibition site (https://dialectic-engine.online),
# so once that's published you don't need to set anything here. Override only if
# you host the print page somewhere else:
#   VITE_PUBLIC_URL=https://your-site.example.com
VITE_PUBLIC_URL=
